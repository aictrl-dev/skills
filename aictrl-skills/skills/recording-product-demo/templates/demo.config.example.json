{
  "app": {
    "name": "Acme Dashboard",
    "baseUrl": "http://localhost:3000",
    "boot": "./demo/boot.sh",
    "healthPath": "/",
    "readyText": "Dashboard"
  },
  "auth": {
    "mode": "none",
    "profileDir": "~/.cache/acme-demo/chrome-profile",
    "statePath": "~/.cache/acme-demo/auth-state.json",
    "loginUrl": "http://localhost:3000/login",
    "expectText": "Sign out"
  },
  "brand": {
    "name": "Acme",
    "color": "#4c6ef5",
    "pronunciation": "Acme"
  },
  "voice": {
    "provider": "elevenlabs",
    "voiceId": "c3QefzBhE1Cx4Yl23IV3",
    "model": "eleven_v3",
    "sttLang": "en"
  },
  "anonymize": {
    "enabled": false,
    "textMap": [["Real Name", "Demo User"], ["realhandle", "demouser"]],
    "faceSrcParts": ["avatars.example.com/u/12345"],
    "keepSrcParts": ["githubusercontent.com/in/"],
    "initials": [["R", "D"]]
  },
  "record": {
    "viewport": [1536, 864],
    "output": [1920, 1080],
    "locale": "en-GB"
  },
  "publish": {
    "kit": true,
    "upload": null
  }
}
